{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "./dist",
    "baseUrl": "./",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "declaration": false,
    "declarationMap": false,
    "strictPropertyInitialization": false,
    "paths": {
      "@/*": ["./src/*"],
      "@atlas-bank/provider-contracts": ["../../packages/provider-contracts/src"],
      "@atlas-bank/shared": ["../../packages/shared/dist"]
    }
  },
  "include": ["src/**/*"]
}
