# App
NODE_ENV=development
PORT=4000
CORS_ORIGINS=http://localhost:3000
APP_URL=http://localhost:3000

# Auth — REQUIRED in production. Generate with: openssl rand -hex 32
JWT_SECRET=your-jwt-secret-here-change-in-production
ACCESS_TOKEN_TTL=3600
REFRESH_TOKEN_TTL=2592000
# Cookie domain shared by web + api in production (e.g. .atlas-bank.com)
COOKIE_DOMAIN=

# PII encryption at rest — REQUIRED in production. 32 bytes hex: openssl rand -hex 32
ENCRYPTION_KEY=

# Dev-only auth bypass. IGNORED when NODE_ENV=production.
SKIP_AUTH=false

# Database — DATABASE_URL takes precedence over the DB_* fields when set.
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=atlas
DB_PASSWORD=atlas
DB_NAME=atlas_bank

# Swan
SWAN_API_URL=https://api.sandbox.swan.io
SWAN_OAUTH_URL=https://oauth.sandbox.swan.io
SWAN_CLIENT_ID=your-swan-client-id
SWAN_CLIENT_SECRET=your-swan-client-secret
SWAN_PROJECT_ID=your-swan-project-id
SWAN_WEBHOOK_SECRET=your-swan-webhook-secret
SWAN_SANDBOX=true

# Redis — REQUIRED in production (OTP, sessions, rate limiting).
REDIS_URL=redis://localhost:6379

# Email (Resend) — sends OTP, welcome, transfer confirmation, incoming-payment
# (money received), payment-request, and card freeze/unfreeze emails. Sending is
# skipped (logged only) when unset.
# RESEND_DOMAIN must be a verified sending domain in Resend (from: noreply@<domain>).
RESEND_API_KEY=
RESEND_DOMAIN=atlasbank.io

# Observability
SENTRY_DSN=

# FX Provider (frankfurter | currencycloud)
FX_PROVIDER=frankfurter

# CurrencyCloud (required when FX_PROVIDER=currencycloud)
CURRENCYCLOUD_LOGIN_ID=
CURRENCYCLOUD_API_KEY=
CURRENCYCLOUD_ENV=demo
