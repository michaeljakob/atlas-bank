NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Dev-only auth bypass. IGNORED when NODE_ENV=production.
SKIP_AUTH=false

# Analytics (optional) — PostHog
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# Logo.dev publishable key — used server-side by the /api/logo proxy to render
# real company/merchant logos. Get one at https://logo.dev. Logos fall back to
# initials when unset.
NEXT_PUBLIC_LOGO_DEV_KEY=
